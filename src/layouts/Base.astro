---
import '../styles/global.css';
import site from '../data/site.json';
const { title = `${site.brand.ka} — ძაღლები ეძებენ სახლს` } = Astro.props;
const desc = site.footer.about.ka;
---
<!doctype html>
<html lang="ka">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={desc} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,500&family=Onest:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="has-bar" data-lang="ka">
  <slot />
</body>
</html>
